## Docker compose environment for kin-office (OnlyOffice Direct)
##
## Copy to `.env` and adjust before running:
##   cp .env.example .env
##

# Path prefix proxied by Kin nginx (default /kin-office)
# KIN_OFFICE_PREFIX=/kin-office

# Optional: public base URL for direct connector (usually inferred from X-Forwarded-* headers)
# DIRECT_PUBLIC_BASE_URL=https://your-host/kin-office/direct
