## Docker compose environment for Nextcloud stack
##
## Copy to `.env` and set real values before running:
##   cp .env.example .env
##

# Nextcloud bootstrap admin (dev)
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me

# Optional: OIDC bootstrap defaults (Nextcloud user_oidc)
# KIN_OIDC_HOST=your-lan-hostname
# KIN_OIDC_PROVIDER_ID=kin
# KIN_OIDC_CLIENT_ID=kin-nextcloud
# KIN_OIDC_CLIENT_SECRET=kin-nextcloud-secret
# KIN_OIDC_DISCOVERY_URI=https://host.docker.internal:9219/.well-known/openid-configuration

