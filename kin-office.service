[Unit]
Description=Kin Office Module - Nextcloud with OnlyOffice
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/opt/kin/modules/kin-office/kin-office-wrapper.sh
ExecStop=/usr/bin/docker-compose -f /opt/kin/modules/kin-office/docker-compose.yml down
ExecReload=/opt/kin/modules/kin-office/kin-office-wrapper.sh
User=root
Group=root

[Install]
WantedBy=multi-user.target
